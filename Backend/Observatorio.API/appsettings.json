{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "${Jwt:Key}",
    "Issuer": "ObservatorioAPI",
    "Audience": "ObservatorioAPIUsers",
    "ExpiresInMinutes": 60
  },
  "GoogleAuth": {
    "ClientId": "${ID_CLIENTE}"
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  }
} 